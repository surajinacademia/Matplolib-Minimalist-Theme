# CMU Sans Serif font settings for presentations

# Font settings
font.family: sans-serif
font.sans-serif: CMU Sans Serif


text.usetex: True
text.latex.preamble : \usepackage{amsmath} \usepackage{amssymb} 
 
# Font sizes
font.size: 12
axes.labelsize: 12
xtick.labelsize: 10
ytick.labelsize: 10
legend.fontsize: 10 